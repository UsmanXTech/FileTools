<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/pluginCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="20dp"
    app:cardBackgroundColor="@color/bg_surface"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Icon background -->
        <androidx.cardview.widget.CardView
            android:id="@+id/iconBackground"
            android:layout_width="52dp"
            android:layout_height="52dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/ivPluginIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:tint="@color/white"/>

        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvPluginName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/inter_semibold"
            android:text="Plugin Name"/>

        <TextView
            android:id="@+id/tvPluginDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="@font/inter_regular"
            android:text="Description"
            android:maxLines="2"/>

        <TextView
            android:id="@+id/tvToolCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="11sp"
            android:textColor="@color/accent_blue"
            android:fontFamily="@font/inter_semibold"
            android:text="6 tools"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
